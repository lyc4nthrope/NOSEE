# ──────────────────────────────────────────────────────────────
# MONITOREO — Google Analytics 4 + Prometheus (ISO/IEC 25010)
# ──────────────────────────────────────────────────────────────

# Google Analytics 4 — Reemplazar con tu Measurement ID real
# Obtener en: https://analytics.google.com → Admin → Data Streams
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Prometheus Metrics Server — iniciar con: cd monitoring && docker compose up
# Dejar vacío para deshabilitar (las métricas solo se loguean en consola dev)
VITE_METRICS_SERVER_URL=http://localhost:3001

# ──────────────────────────────────────────────────────────────
#SUPABASE
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

#CLOUDINARY
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_URL=your_cloudinary_url
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_or_signed_upload_preset
VITE_CLOUDINARY_UPLOAD_FOLDER=your_cloudinary_upload_folder
VITE_CLOUDINARY_ENABLE_MODERATION=false
VITE_CLOUDINARY_MODERATION_PROVIDER=aws_rek
VITE_REQUIRE_IMAGE_MODERATION=false
VITE_TEXT_MODERATION_SCORE_THRESHOLD=3
VITE_IMAGE_MODERATION_CONFIDENCE_THRESHOLD=0.75

#FEATURE FLAGS
VITE_ENABLE_AUTO_STORE=true
VITE_ENABLE_BARCODE_SCAN=true

# ──────────────────────────────────────────────────────────────
# N8N CHAT WEBHOOK
VITE_N8N_CHAT_WEBHOOK_URL=https://tu-n8n.com/webhook/chat

# ──────────────────────────────────────────────────────────────
#INFINITE SCROLL
VITE_INFINITE_SCROLL_TRIGGER_DISTANCE_PX=220
VITE_INFINITE_SCROLL_COOLDOWN_MS=500
VITE_HOME_PUBLICATIONS_PAGE_SIZE=12
VITE_PUBLICATIONS_PAGE_SIZE=12
VITE_STORES_PAGE_SIZE=12

#SENTRY
VITE_SENTRY_DSN=
